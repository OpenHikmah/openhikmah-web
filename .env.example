# Copy this file to .env.local and fill in all values before running the app.
# Never commit .env.local — it is gitignored.

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Which LLM provider to use. Set to "gemini" for dev to save costs.
# Default: claude (production-grade theological reasoning)
AI_PROVIDER=claude           # claude | gemini

# Anthropic — required when AI_PROVIDER=claude
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=             # optional override, default: claude-opus-4-7

# Google Gemini — required when AI_PROVIDER=gemini
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=                # optional override, default: gemini-2.0-flash
# Embeddings are always Gemini (Anthropic has none); used for semantic search.
# A GEMINI_API_KEY is required to seed embeddings even when AI_PROVIDER=claude.
# Embedding model. Default gemini-embedding-001, reduced to 768 dims via the REST
# outputDimensionality param to match the verse_embeddings vector(768) column.
GEMINI_EMBEDDING_MODEL=      # optional override, default: gemini-embedding-001

# ─── Quran Foundation — Two environments ──────────────────────────────────────
#
# ⚠️  PRE-PRODUCTION (use this for local dev — full auth + social features)
#     Client ID:     <provided by Quran Foundation>
#     Client Secret: <provided by Quran Foundation>
#     Auth endpoint: https://prelive-oauth2.quran.foundation
#     Limited data, but all features (sign-in, bookmarks, social) enabled.
#
# ⚠️  PRODUCTION (for live deployment on openhikmah.com)
#     Client ID:     <provided by Quran Foundation>
#     Client Secret: <provided by Quran Foundation>
#     Auth endpoint: https://oauth2.quran.foundation
#     ⚠️  Auth/user features are disabled by default — must request QF to enable.
#
# Both environments share:
#     API base: https://apis.quran.foundation
#
# ─── Server-side only (never expose to browser) ───────────────────────────────
QF_CLIENT_SECRET=
# ⚠️  API base MUST match auth base — pre-prod tokens don't work against the prod API:
#   Pre-Production: https://apis-prelive.quran.foundation
#   Production:     https://apis.quran.foundation
QF_API_BASE=https://apis-prelive.quran.foundation
# Use prelive auth base for dev, oauth2.quran.foundation for production
QF_AUTH_BASE=https://prelive-oauth2.quran.foundation
# JWKS endpoint used to verify QF access-token signatures. Optional — defaults to
# ${QF_AUTH_BASE}/.well-known/jwks.json (falls back to /oauth2/.well-known/jwks.json).
# Set only if QF publishes its keys at a non-standard path.
QF_JWKS_URL=

# ─── Public — safe to expose to the browser (NEXT_PUBLIC_ prefix) ─────────────
NEXT_PUBLIC_QF_CLIENT_ID=
# Must match QF_AUTH_BASE above
NEXT_PUBLIC_QF_AUTH_BASE=https://prelive-oauth2.quran.foundation
NEXT_PUBLIC_APP_URL=http://localhost:3000   # IMPORTANT: use http://localhost:3000 for local dev
# Authorization endpoint path (default /oauth2/auth for Ory Hydra).
# Set to /oauth2/authorize if your QF instance uses the standard RFC 6749 path.
NEXT_PUBLIC_QF_AUTHORIZE_PATH=             # optional, default: /oauth2/auth
# NOTE: the OAuth2 scope is hardcoded in lib/pkce.ts (openid offline_access user) —
# not env-configurable. `collection` is intentionally excluded: the production QF
# client isn't approved for it and requesting it fails sign-in with invalid_scope.

# ─── Redirect URI (register this with Quran Foundation) ───────────────────────
# Dev:  http://localhost:3000/callback
# Prod: https://openhikmah.com/callback

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (spin up Postgres with the docker run command in README):
DATABASE_URL=postgresql://openh:devpassword@localhost:5432/open_hikmah
# docker-compose uses DB_PASSWORD to set the Postgres password:
DB_PASSWORD=

# ─── Redis (optional accelerator) ─────────────────────────────────────────────
# Externalizes the token/JWKS caches, the AI rate limiter, and the query
# embedding cache so they survive restarts and don't contend on Postgres.
# OPTIONAL: leave REDIS_URL unset and the app falls back to in-process/Postgres
# behavior (a Redis outage never takes the site down). docker-compose runs a
# redis service automatically and wires REDIS_URL for you; set REDIS_PASSWORD to
# enable auth (empty = no auth). For a non-compose / external Redis, set REDIS_URL
# directly, e.g. redis://:password@host:6379
REDIS_URL=
# Used by docker-compose to set the redis password and build the app's REDIS_URL.
REDIS_PASSWORD=

# ─── Admin panel ──────────────────────────────────────────────────────────────
# Comma-separated allowlist of QF user ids (the `sub` / qf_id) granted access to
# the /admin console. FAIL-CLOSED: unset/empty = nobody is an admin. There is no
# DB role — membership lives here so it can't be escalated from inside the app.
ADMIN_QF_IDS=
# Optional: USD price per 1k AI tokens, used only to estimate cost on the Admin
# AI & Cost page. Leave unset to show token counts without a dollar figure.
AI_USD_PER_1K_TOKENS=

# ─── Dev/test login bypass (development only — cannot run in production) ───────
# Lets you sign in as a fixed dev user WITHOUT completing QF OAuth — useful for
# testing the admin console when your redirect_uri isn't registered with QF yet.
# HARD-DISABLED when NODE_ENV=production (no override), and otherwise inert unless
# BOTH DEV_AUTH_TOKEN and DEV_AUTH_QF_ID are set. To use it, run the app in dev
# mode (`next dev`) and call `window.__devLogin('<DEV_AUTH_TOKEN>')` in the browser
# console. To make this dev user an admin, add the SAME DEV_AUTH_QF_ID to ADMIN_QF_IDS.
# a long random secret you choose; the "password"
DEV_AUTH_TOKEN=
# the dev user's qf_id (you define it, e.g. dev-admin)
DEV_AUTH_QF_ID=
# optional, default: devadmin
DEV_AUTH_USERNAME=devadmin

# ─── IMPORTANT: Restart the dev server after editing this file ────────────────
# NEXT_PUBLIC_* variables are baked into the client bundle at startup.
