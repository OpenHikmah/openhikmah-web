# pre-commit — quiet on success, full output only on failure (mirrors pre-push).
# Each step's output is captured and printed only if that step fails.

step() {
  label=$1
  shift
  output=$("$@" 2>&1)
  status=$?
  if [ "$status" -ne 0 ]; then
    printf '%s\n' "$output" >&2
    echo "pre-commit: $label FAILED — commit aborted." >&2
    exit 1
  fi
}

# 1. Strict guards: branch, focused tests, leftover debug, secret scan (fast)
step "guards" node scripts/precommit-checks.mjs

# 2. ESLint on staged files, zero warnings tolerated
step "lint" npx lint-staged

# 3. Project-wide typecheck
step "typecheck" npm run typecheck

# 4. Full unit test suite
step "tests" npm run test:ci

echo "pre-commit: checks passed."
